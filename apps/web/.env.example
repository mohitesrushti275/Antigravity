# ══════════════════════════════════════════════════
# 21st.dev — Environment Variables Template
# Copy this file to .env.local and fill in your values
# ══════════════════════════════════════════════════

# ── Supabase (Required) ──
# Get from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Clerk Authentication (Required) ──
# Get from: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/components
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/components

# ── AWS S3 / Cloudflare R2 Storage (Required) ──
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
S3_BUCKET_NAME=21st-components
NEXT_PUBLIC_CDN_URL=https://your-cdn-url.com

# Cloudflare R2 alternative:
# AWS_REGION=auto
# AWS_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com

# ── AI Services (Optional — enables Magic Chat) ──
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Upstash Redis (Optional — enables rate limiting + caching) ──
# Get from: https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ── Resend Email (Optional) ──
# Get from: https://resend.com
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@21st.dev

# ── Sentry Monitoring (Optional) ──
# Get from: https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=21st-web
SENTRY_AUTH_TOKEN=sntrys_...

# ── Application ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=your-random-secret-here

# ══════════════════════════════════════════════════
# SETUP
# ══════════════════════════════════════════════════
#
# 1. cp .env.example .env.local
# 2. Fill in Required values above
# 3. Run: pnpm dev
#
# ══════════════════════════════════════════════════
